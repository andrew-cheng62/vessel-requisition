# ─────────────────────────────────────────────────────────────
# VesselReq — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# On Railway: set these in the Railway dashboard → Variables tab.
# ─────────────────────────────────────────────────────────────

# Database (Railway provides this automatically if you add a Postgres plugin)
# DATABASE_URL=postgresql://user:password@host:5432/vesselreq

DATABASE_URL=postgresql://postgres:andrewkikott@localhost/vessel-requisitions
SECRET_KEY=change-this-to-something-random
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS — your production frontend URL (no trailing slash)--- uncomment when alive
# ALLOWED_ORIGIN=https://vesselreq.com
ALLOWED_ORIGIN=http://localhost:5173
